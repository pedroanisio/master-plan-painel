# Production / UAT environment for docker-compose.prod.yml.
# Copy to `.env` and fill in. NEVER commit the real .env.
#
#   cp .env.example .env

# REQUIRED. Bearer-token (JWT) signing key. Without a stable, secret value the
# API falls back to a per-process random key, invalidating every session on each
# restart — and a shared/guessable value lets anyone forge sessions.
# Generate a fresh one:
#   openssl rand -hex 32
MASTER_PLAN_SECRET=

# Public hostname Caddy serves and auto-provisions a TLS certificate for.
#   build-journal.dev        production (automatic HTTPS)
#   uat.build-journal.dev    UAT (automatic HTTPS)
#   :80                      plain HTTP, behind an external TLS terminator (LB)
SITE_ADDRESS=build-journal.dev
